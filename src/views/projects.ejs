<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <p>Here are a few of our partner projects:</p>
        <ul>
            <% for (var i=0; i < projects.length; i++) { %>
                <li>
                    <strong>
                        <%= projects[i].title %><br>
                     <%= projects[i].location %> - <%= projects[i].project_date %>
                    </strong>: <br> <%= projects[i].description %>
                </li>
                <% } %>
        </ul>
    </main>
    <%- include('partials/footer') %>