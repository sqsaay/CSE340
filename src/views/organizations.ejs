<%- include('partials/header') %>

        <main>
                <h1>
                        <%= title %>
                </h1>
                <h2>
                        <%= organizationDetails.name %>
                </h2>
                <img src="/images/<%= organizationDetails.logo_filename %>" alt="<%= organizationDetails.name %> logo">

                <p>Description: <%= organizationDetails.description %>
                </p>

                <h3>Service Projects</h3>
                <ul>
                        <% organizations.forEach(organization=> { %>
                                <li><img src="/images/<%= organization.logo_filename %>"
                                                alt="<%= organization.name %> logo"><a
                                                href="/organization/<%= organization.organization_id %>">
                                                <%= organization.name %>
                                        </a>: <%= organization.contact_email %>
                                </li>
                                <% }); %>
                </ul>   
        </main>
        <%- include('partials/footer') %>